{
  "name": "material-dashboard",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "deploy": "ng build --base-href \"/angular-material-dashboard/\" && find dist/material-dashboard/browser -name \"*.css\" -o -name \"*.js\" | xargs sed -i '' 's|/assets/|/angular-material-dashboard/assets/|g' && npx angular-cli-ghpages --dir=dist/material-dashboard/browser"
  },
  "private": true,
  "packageManager": "npm@11.4.0",
  "dependencies": {
    "@angular/common": "^21.2.0",
    "@angular/compiler": "^21.2.0",
    "@angular/core": "^21.2.0",
    "@angular/forms": "^21.2.0",
    "@angular/platform-browser": "^21.2.0",
    "@angular/router": "^21.2.0",
    "chart.js": "^4.5.1",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^21.2.3",
    "@angular/cli": "^21.2.3",
    "@angular/compiler-cli": "^21.2.0",
    "angular-cli-ghpages": "^3.0.2",
    "jsdom": "^28.0.0",
    "less": "^4.6.4",
    "prettier": "^3.8.1",
    "typescript": "~5.9.2",
    "vitest": "^4.0.8"
  }
}
